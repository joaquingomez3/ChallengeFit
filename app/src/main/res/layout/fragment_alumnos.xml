<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="16dp"
    tools:context=".ui.trainer.AlumnosFragment">

    <!-- Header: Icono Grupo + Mis Alumnos + Lupa -->
    <ImageView
        android:id="@+id/ivIconoAlumnos"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/icon_students"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#4D5D53" />

    <TextView
        android:id="@+id/tvTituloAlumnos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Mis Alumnos"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivIconoAlumnos"
        app:layout_constraintStart_toEndOf="@id/ivIconoAlumnos"
        app:layout_constraintTop_toTopOf="@id/ivIconoAlumnos" />

<!--    <ImageView-->
<!--        android:id="@+id/ivSearchAlumnos"-->
<!--        android:layout_width="24dp"-->
<!--        android:layout_height="24dp"-->
<!--        android:src="@android:drawable/ic_menu_search"-->
<!--        app:layout_constraintBottom_toBottomOf="@id/tvTituloAlumnos"-->
<!--        app:layout_constraintEnd_toEndOf="parent"-->
<!--        app:layout_constraintTop_toTopOf="@id/tvTituloAlumnos"-->
<!--        app:tint="#4D5D53" />-->

    <!-- RecyclerView para los Alumnos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAlumnos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloAlumnos"
        tools:listitem="@layout/item_student" />

</androidx.constraintlayout.widget.ConstraintLayout>
